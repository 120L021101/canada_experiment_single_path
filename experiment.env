#!/usr/bin/env bash
# ============================================================
# experiment.env — Single-path experiment configuration
# Phase 1: Network measurement (UDP RTT + traceroute)
# Phase 2: MoQ video streaming (publisher → relay → subscriber)
# ============================================================

# --- Subscriber ---
SUB_INTERFACE="enp9s0"

RELAY_HOST="root@5.75.186.96"
RELAY_PASS="spear123"
RELAY_INTERFACE="eth0"

PUB_HOST="zujizhou@80.112.145.190"
PUB_PORT="37863"
PUB_PASS="zhou3079"

# === Phase 1: Network Measurement ===
MEASURE_IMAGE="ghcr.io/120l021101/canada_experiment_single_path/measurement:latest"
RELAY_ECHO_PORT=5201
RTT_DURATION=60                 # seconds of RTT probing per run
RTT_INTERVAL=10                 # probe interval in milliseconds
TRACEROUTE_ROUNDS=5

# === Phase 2: MoQ Video Streaming ===
MOQ_SUB_IMAGE="ghcr.io/120l021101/canada_experiment/moq-subscriber:latest"
RELAY_REPO="/root/multipath-conferencing-over-quic/moq-examples"
RELAY_BINARY="./target/release/tquic_moq_relay"
RELAY_MOQ_PORT=4443
PUB_REPO="/home/zujizhou/multipath-conferencing-over-quic/moq-examples"
PUB_BINARY="./target/release/tquic_moq_publisher"
PUB_VIDEO="/home/zujizhou/multipath-conferencing-over-quic/sample_video/720p50_mobcal_ter.y4m"
PUB_INTERFACE="wlp0s20f3"
PUB_LOOP_COUNT=3
PUBLISHER_TIMEOUT=120           # max seconds to wait for publisher
SUBSCRIBER_GRACE=25             # seconds after publisher finishes
SVC_ENABLED="--svc"

# === General ===
TOTAL_RUNS=50
INTER_RUN_GAP=10
RESULT_DIR="./results"

COLLECT_HOST="spear@ssh.nitindermohan.com"
COLLECT_PASS="Spearlab789!"
COLLECT_DIR="/home/spear/zujizhou/single_path_experiment_results"
