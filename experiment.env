#!/usr/bin/env bash
# ============================================================
# experiment.env — Single-path network measurement configuration
# ============================================================

# --- Subscriber (Finland, runs Docker measurement container) ---
SUB_HOST="root@204.168.252.61"
SUB_PASS="spear123"
SUB_IMAGE="ghcr.io/120l021101/canada_experiment_single_path/measurement:latest"
SUB_INTERFACE="eth0"            # network interface for measurement

# --- Relay (Germany, runs bare Python UDP echo server) ---
RELAY_HOST="root@5.75.186.96"
RELAY_PASS="spear123"
RELAY_ECHO_PORT=5201            # UDP port for echo server

# --- Measurement parameters ---
RTT_DURATION=60                 # seconds of RTT probing per run
RTT_INTERVAL=10                 # probe interval in milliseconds
TRACEROUTE_ROUNDS=5             # traceroute repetitions per run
TOTAL_RUNS=3                    # number of measurement runs
INTER_RUN_GAP=5                 # seconds between runs

# --- Results ---
RESULT_DIR="./results"

# --- Data collection host ---
COLLECT_HOST="spear@ssh.nitindermohan.com"
COLLECT_PASS="Spearlab789!"
COLLECT_DIR="/home/spear/zujizhou/single_path_measurement_results"
